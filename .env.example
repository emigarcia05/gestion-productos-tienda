# 1) Copiá este archivo a .env (en esta misma carpeta):
#    cp .env.example .env
# 2) En .env reemplazá la URL por tu connection string de Neon.
# 3) Aplicar migraciones a la BD: npm run db:migrate-deploy
# .env no se sube a Git (está en .gitignore).

DATABASE_URL="postgresql://usuario:password@tu-endpoint.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://usuario:password@tu-endpoint.neon.tech/neondb?sslmode=require"