# Base de datos PostgreSQL en Neon (https://neon.tech)
# Copia este archivo como .env y rellena con tus credenciales reales

# URL con pooler de PgBouncer (para la app en producción/serverless)
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# URL directa (para migraciones de Prisma)
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require"
