generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Proveedor {
  id          String     @id @default(cuid())
  nombre      String
  codigoUnico String     @unique
  sufijo      String     @unique
  productos   Producto[]
  pedidos     Pedido[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("proveedores")
}

model Producto {
  id                   String              @id @default(cuid())
  codProdProv          String
  codExt               String              @unique
  descripcion          String
  precioLista          Float
  precioVentaSugerido  Float
  descuentoProducto    Float               @default(0)
  descuentoCantidad    Float               @default(0)
  cxTransporte         Float               @default(0)
  disponible           Boolean             @default(true)
  proveedorId          String
  proveedor            Proveedor           @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  itemsTienda          ItemTiendaProducto[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([proveedorId])
  @@map("productos")
}

model ImportLog {
  id          String   @id @default(cuid())
  filename    String
  status      String   @default("pending")
  totalRows   Int      @default(0)
  creados     Int      @default(0)
  actualizados Int     @default(0)
  eliminados  Int      @default(0)
  errores     Int      @default(0)
  proveedorId String?
  createdAt   DateTime @default(now())

  @@map("import_logs")
}

// ─── Lista TiendaColor (API Dux Software) ─────────────────────────────────

model ItemTienda {
  id               String               @id @default(cuid())
  codItem          String               @unique   // cod_item de Dux
  descripcion      String
  rubro            String?
  subRubro         String?
  marca            String?
  proveedorDux     String?              // nombre del proveedor en Dux
  codigoExterno    String?
  costo            Float                @default(0)
  porcIva          Float                @default(21)
  precioLista      Float                @default(0)
  precioMayorista  Float                @default(0)
  stockGuaymallen  Float                @default(0)
  stockMaipu       Float                @default(0)
  habilitado       Boolean              @default(true)
  ultimaImpresion  DateTime?
  productos        ItemTiendaProducto[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([rubro])
  @@index([marca])
  @@map("items_tienda")
}

// ─── Tabla de vínculo ItemTienda <-> Producto (many-to-many) ──────────────

model ItemTiendaProducto {
  itemTiendaId String
  productoId   String
  itemTienda   ItemTienda @relation(fields: [itemTiendaId], references: [id], onDelete: Cascade)
  producto     Producto   @relation(fields: [productoId],   references: [id], onDelete: Cascade)

  @@id([itemTiendaId, productoId])
  @@index([productoId])
  @@map("items_tienda_productos")
}

model SyncLog {
  id           String   @id @default(cuid())
  tipo         String   @default("auto")   // "auto" | "manual"
  status       String   @default("ok")     // "ok" | "error"
  creados      Int      @default(0)
  actualizados Int      @default(0)
  deshabilitados Int    @default(0)
  totalApi     Int      @default(0)
  duracionMs   Int      @default(0)
  error        String?
  createdAt    DateTime @default(now())

  @@map("sync_logs")
}

// ─── Pedidos a proveedores ─────────────────────────────────────────────────

model Pedido {
  id          String       @id @default(cuid())
  tipo        String       // "urgente" | "reposicion"
  estado      String       @default("borrador")  // "borrador" | "enviado" | etc.
  sucursal    String       // "guaymallen" | "maipu"
  proveedorId String
  proveedor   Proveedor    @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  items       PedidoItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([proveedorId])
  @@map("pedidos")
}

model PedidoItem {
  id                   String  @id @default(cuid())
  pedidoId             String
  pedido               Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  codExt               String  // código en lista proveedor
  codTienda            String  // código en lista tienda
  descripcionProveedor String
  descripcionTienda    String
  cantidad             Int     @default(1)

  @@index([pedidoId])
  @@map("pedido_items")
}
