// ─── Neon / PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Proveedor {
  id           String   @id @default(cuid())
  nombre       String   @unique
  sufijo       String   @unique
  codigoUnico  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("proveedores")
}
