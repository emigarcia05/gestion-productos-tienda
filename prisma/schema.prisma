// ─── Neon / PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Proveedor {
  id              String   @id @default(cuid())
  nombre          String   @unique
  prefijo         String   @unique
  codigoUnico     String   @map("codigo_unico")
  idProveedorDux  String?  @map("id_proveedor_dux") // ID del proveedor en DUX (para POST actualización costos)
  whatsapp        String?  @map("whatsapp") // Número para envío de pedido por WhatsApp (internacional sin +)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  listaPrecios     ListaPrecioProveedor[]
  itemsPedidoEnvio ItemPedidoEnvio[]

  @@map("proveedores")
}

// Sucursales: código estable (guaymallen, maipu), nombre, whatsapp (emisor), id DUX, Phone Number ID (Meta API).
model Sucursal {
  id             String   @id @default(cuid())
  codigo         String   @unique // guaymallen | maipu (estable en URLs y FKs)
  nombre         String
  whatsapp       String?  @map("whatsapp")
  phoneNumberId  String?  @map("phone_number_id") // Meta WhatsApp Cloud API: envío sin abrir pestaña
  idDux          String?  @map("id_dux")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  itemsPedidoEnvio ItemPedidoEnvio[]

  @@map("sucursales")
}

model ListaPrecioProveedor {
  id                String   @id @default(uuid())
  idProveedor       String   @map("id_proveedor")
  codProdProveedor  String   @map("cod_prod_proveedor")
  descripcionProveedor String  @map("descripcion_proveedor")
  codExt            String   @map("cod_ext") // ya no unique: varios proveedores pueden compartir el mismo cod_ext (1 tienda → N proveedores)
  pxListaProveedor  Decimal  @map("px_lista_proveedor") @db.Decimal(14, 4)
  pxDolares         Boolean  @map("px_dolares") @default(false) // mapea switch SÍ/NO del modal importar: true = precio × cotizacion_dolar
  cotizacionDolar   Decimal  @map("cotizacion_dolar") @db.Decimal(14, 4) @default(1) // cotización USD → pesos; se usa cuando px_dolares = true
  pxVtaSugerido     Decimal? @map("px_vta_sugerido") @db.Decimal(14, 4)
  marca             String?  // texto marca (proveedor / lista)
  rubro             String?  @map("rubro")
  dtoProveedor      Int      @map("dto_proveedor") @default(0) // descuento proveedor (%)
  dtoMarca          Int      @map("dto_marca") @default(0)
  dtoRubro         Int      @map("dto_rubro") @default(0)
  dtoCantidad       Int      @map("dto_cantidad") @default(0)
  dtoFinanciero     Int      @map("dto_financiero") @default(0)
  cxTransporte       Int      @map("cx_transporte") @default(0)
  pxCompraFinal     Decimal? @map("px_compra_final") @db.Decimal(14, 4) // generada: (px_lista * (px_dolares ? cotizacion_dolar : 1)) - dto_* ... + cx_transporte
  idListaPrecioTienda String? @map("id_lista_precios_tienda") // FK: vincula este ítem proveedor con un ítem del catálogo tienda (1 tienda → N proveedores)
  idPresentacion     String? @map("id_presentacion") // FK: categoría de comparación final (Categoria → Subcategoria → Presentacion)
  habilitado         Boolean  @map("habilitado") @default(true) // mapea opción SÍ/NO del modal importar
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  proveedor         Proveedor        @relation(fields: [idProveedor], references: [id], onDelete: Cascade)
  listaPrecioTienda ListaPrecioTienda? @relation(fields: [idListaPrecioTienda], references: [id], onDelete: SetNull)
  presentacion      PresentacionComparacion? @relation("PresentacionItems", fields: [idPresentacion], references: [id], onDelete: SetNull)
  presentacionesReferencia PresentacionComparacion[] @relation("PresentacionProductoReferencia")

  @@unique([idProveedor, codProdProveedor])
  @@map("precios_proveedores")
}

// ─── Comparación por categorías (Categoria → Subcategoria → Presentacion) ───
model CategoriaComparacion {
  id             String   @id @default(cuid())
  nombre         String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subcategorias  SubcategoriaComparacion[]

  @@map("comparacion_categorias")
}

model SubcategoriaComparacion {
  id             String   @id @default(cuid())
  categoriaId    String   @map("categoria_id")
  nombre         String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  categoria      CategoriaComparacion  @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  presentaciones PresentacionComparacion[]

  @@map("comparacion_subcategorias")
}

model PresentacionComparacion {
  id                   String    @id @default(cuid())
  subcategoriaId        String    @map("subcategoria_id")
  nombre               String
  costoCompraObjetivo   Decimal?   @map("costo_compra_objetivo") @db.Decimal(14, 4)
  idProductoReferencia  String?   @map("id_producto_referencia")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  subcategoria  SubcategoriaComparacion @relation(fields: [subcategoriaId], references: [id], onDelete: Cascade)
  listaPrecios  ListaPrecioProveedor[] @relation("PresentacionItems")
  productoReferencia ListaPrecioProveedor? @relation("PresentacionProductoReferencia", fields: [idProductoReferencia], references: [id], onDelete: SetNull)

  @@map("comparacion_presentaciones")
}

// Catálogo de marcas; se alimenta desde el texto "marca" que viene de la API en precios_tienda.
model Marca {
  id     String   @id @default(cuid())
  nombre String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  listaPreciosTienda ListaPrecioTienda[]

  @@map("marcas")
}

// Alimentada solo por API externa (tabla precios_tienda). Frontend solo lectura; no usar create/update/delete desde UI.
model ListaPrecioTienda {
  id              String   @id @default(uuid())
  codExt          String   @unique @map("cod_ext")
  codTienda       String   @map("cod_tienda")
  rubro           String?
  subRubro        String?  @map("sub_rubro")
  marca           String?  // texto tal cual viene de la API DUX (se mantiene para trazabilidad)
  idMarca         String?  @map("id_marca") // FK a marcas: marca normalizada y vinculada
  proveedor       String?  // texto; cruce con proveedores: WHERE proveedores.nombre ILIKE proveedor
  descripcionTienda String? @map("descripcion_tienda")
  costoCompra     Decimal  @map("costo_compra") @db.Decimal(14, 4)
  pxListaTienda   Decimal  @map("px_lista_tienda") @db.Decimal(14, 4)
  stockMaipu      Int      @map("stock_maipu") @default(0)
  stockGuaymallen  Int      @map("stock_guaymallen") @default(0)
  lastSync        DateTime @default(now()) @map("last_sync")

  marcaRelation   Marca?   @relation(fields: [idMarca], references: [id], onDelete: SetNull)
  listaPreciosProveedores ListaPrecioProveedor[] // 1 tienda → N proveedores (vinculados por id_lista_precios_tienda)

  @@map("precios_tienda")
}

// Progreso de importación (singleton por id) para que el polling desde la sidebar funcione en serverless.
model ImportProgress {
  id               String   @id // ej. "lista-precios"
  running          Boolean  @default(false)
  processed        Int      @default(0)
  total            Int      @default(0)
  resultCreados    Int?     @map("result_creados")
  resultActualizados Int?   @map("result_actualizados")
  resultEliminados Int?     @map("result_eliminados")
  resultErrores    Json?    @map("result_errores") // string[]
  error            String?
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("import_progress")
}

// ─── Enviar Pedido: ítems a enviar.
// Origen: proveedores (id/nombre/prefijo), precios_proveedores (cod_prod_proveedor, descripcion_proveedor, cod_ext),
//         precios_tienda (cod_tienda, cod_ext, descripcion_tienda; vacío si no existe vínculo).
model ItemPedidoEnvio {
  id                  String   @id @default(uuid())
  idProveedor         String   @map("id_proveedor")
  tipoPedido          String   @map("tipo_de_pedido") // URGENTE | TINTOMETRICO | REPOSICION
  sucursalCodigo     String   @map("sucursal") // FK a sucursales.codigo
  codExt             String   @map("cod_ext")
  codProveedor       String   @map("cod_proveedor") // cod_prod_proveedor
  codTienda          String?  @map("cod_tienda") // precios_tienda.cod_tienda; vacío si no existe
  descripcionProveedor String  @map("descripcion_proveedor")
  descripcionTienda   String?  @map("descripcion_tienda") // precios_tienda; vacío si no existe
  cantPedir          Int      @map("cant_pedir") @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  proveedor Proveedor @relation(fields: [idProveedor], references: [id], onDelete: Cascade)
  sucursal  Sucursal  @relation(fields: [sucursalCodigo], references: [codigo], onDelete: Restrict)

  @@map("pedidos_envio")
}
