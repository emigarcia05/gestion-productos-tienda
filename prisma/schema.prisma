generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Lista Proveedores ─────────────────────────────────────────────────────

model Proveedor {
  id                 String             @id @default(cuid())
  nombre             String
  codigoUnico        String             @unique
  sufijo             String             @unique
  productosProveedor ProductoProveedor[]
  pedidos            Pedido[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("proveedores")
}

/// Productos de la lista de proveedores. Vinculados a ItemTienda por codigoExterno.
model ProductoProveedor {
  id                   String     @id @default(cuid())
  codigoExterno        String     @unique @map("codigo_externo")
  codProdProv          String     @map("cod_prod_prov")
  descripcion          String
  precioLista          Float      @map("precio_lista")
  precioVentaSugerido  Float      @map("precio_venta_sugerido")
  descuentoProducto   Float      @default(0) @map("descuento_producto")
  descuentoCantidad    Float      @default(0) @map("descuento_cantidad")
  cxTransporte         Float      @default(0) @map("cx_transporte")
  disponible           Boolean    @default(true)
  proveedorId          String     @map("proveedor_id")
  proveedor            Proveedor  @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  tienda               ItemTienda[]
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  @@index([proveedorId])
  @@index([codigoExterno])
  @@map("lista_proveedores")
}

model ImportLog {
  id          String   @id @default(cuid())
  filename    String
  status      String   @default("pending")
  totalRows   Int      @default(0)
  creados     Int      @default(0)
  actualizados Int     @default(0)
  eliminados  Int      @default(0)
  errores     Int      @default(0)
  proveedorId String?
  createdAt   DateTime @default(now())

  @@map("import_logs")
}

// ─── Lista Tienda (API Dux / TiendaColor) ──────────────────────────────────

/// Ítems de la lista tienda. Relación formal con ProductoProveedor vía productoProveedorId (codigoExterno).
model ItemTienda {
  id                   String             @id @default(cuid())
  codItem              String             @unique @map("cod_item")
  codigoExterno        String?            @map("codigo_externo")
  descripcion          String
  rubro                String?
  subRubro             String?            @map("sub_rubro")
  marca                String?
  proveedorDux         String?            @map("proveedor_dux")
  costo                Float              @default(0)
  porcIva              Float              @default(21) @map("porc_iva")
  precioLista          Float              @default(0) @map("precio_lista")
  precioMayorista      Float              @default(0) @map("precio_mayorista")
  stockGuaymallen      Float              @default(0) @map("stock_guaymallen")
  stockMaipu           Float              @default(0) @map("stock_maipu")
  habilitado           Boolean            @default(true)
  ultimaImpresion      DateTime?          @map("ultima_impresion")
  productoProveedorId  String?            @map("producto_proveedor_id")
  productoProveedor    ProductoProveedor? @relation(fields: [productoProveedorId], references: [id], onDelete: SetNull)
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@index([codigoExterno])
  @@index([rubro])
  @@index([marca])
  @@index([habilitado])
  @@map("lista_tienda")
}

model SyncLog {
  id             String   @id @default(cuid())
  tipo           String   @default("auto")
  status         String   @default("ok")
  creados        Int      @default(0)
  actualizados   Int      @default(0)
  deshabilitados Int      @default(0)
  totalApi       Int      @default(0)
  duracionMs     Int      @default(0)
  error          String?
  createdAt      DateTime @default(now())

  @@map("sync_logs")
}

// ─── Pedidos a proveedores ─────────────────────────────────────────────────

model Pedido {
  id          String       @id @default(cuid())
  tipo        String
  estado      String       @default("borrador")
  sucursal    String
  proveedorId String
  proveedor   Proveedor    @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  items       PedidoItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([proveedorId])
  @@map("pedidos")
}

model PedidoItem {
  id                   String  @id @default(cuid())
  pedidoId             String
  pedido               Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  codExt               String
  codTienda            String
  descripcionProveedor String
  descripcionTienda    String
  cantidad             Int     @default(1)

  @@index([pedidoId])
  @@map("pedido_items")
}
