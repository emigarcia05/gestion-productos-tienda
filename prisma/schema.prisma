generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Lista Proveedores ─────────────────────────────────────────────────────

model Proveedor {
  id                 String             @id @default(cuid())
  nombre             String
  codigoUnico        String             @unique
  sufijo             String             @unique
  productosProveedor ProductoProveedor[]
  pedidos            Pedido[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("proveedores")
}

/// Productos de la lista de proveedores. Vinculados a ItemTienda por codigoExterno.
model ProductoProveedor {
  id                   String     @id @default(cuid())
  codigoExterno        String     @unique
  codProdProv          String
  descripcion          String
  precioLista          Float
  precioVentaSugerido  Float
  descuentoProducto   Float      @default(0)
  descuentoCantidad    Float      @default(0)
  cxTransporte         Float      @default(0)
  disponible           Boolean    @default(true)
  proveedorId          String
  proveedor            Proveedor  @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  tienda               ItemTienda[]
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([proveedorId])
  @@index([codigoExterno])
  @@map("productos")
}

model ImportLog {
  id          String   @id @default(cuid())
  filename    String
  status      String   @default("pending")
  totalRows   Int      @default(0)
  creados     Int      @default(0)
  actualizados Int     @default(0)
  eliminados  Int      @default(0)
  errores     Int      @default(0)
  proveedorId String?
  createdAt   DateTime @default(now())

  @@map("import_logs")
}

// ─── Lista Tienda (API Dux / TiendaColor) ──────────────────────────────────

/// Ítems de la lista tienda. Relación formal con ProductoProveedor vía productoProveedorId (codigoExterno).
model ItemTienda {
  id               String             @id @default(cuid())
  codItem          String             @unique
  codigoExterno    String?
  descripcion      String
  rubro            String?
  subRubro         String?
  marca            String?
  proveedorDux     String?
  costo            Float              @default(0)
  porcIva          Float              @default(21)
  precioLista      Float              @default(0)
  precioMayorista  Float              @default(0)
  stockGuaymallen  Float              @default(0)
  stockMaipu       Float              @default(0)
  habilitado       Boolean            @default(true)
  ultimaImpresion  DateTime?
  productoProveedorId  String?
  productoProveedor    ProductoProveedor? @relation(fields: [productoProveedorId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([codigoExterno])
  @@index([rubro])
  @@index([marca])
  @@index([habilitado])
  @@map("items_tienda")
}

model SyncLog {
  id             String   @id @default(cuid())
  tipo           String   @default("auto")
  status         String   @default("ok")
  creados        Int      @default(0)
  actualizados   Int      @default(0)
  deshabilitados Int      @default(0)
  totalApi       Int      @default(0)
  duracionMs     Int      @default(0)
  error          String?
  createdAt      DateTime @default(now())

  @@map("sync_logs")
}

// ─── Pedidos a proveedores ─────────────────────────────────────────────────

model Pedido {
  id          String       @id @default(cuid())
  tipo        String
  estado      String       @default("borrador")
  sucursal    String
  proveedorId String
  proveedor   Proveedor    @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  items       PedidoItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([proveedorId])
  @@map("pedidos")
}

model PedidoItem {
  id                   String  @id @default(cuid())
  pedidoId             String
  pedido               Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  codExt               String
  codTienda            String
  descripcionProveedor String
  descripcionTienda    String
  cantidad             Int     @default(1)

  @@index([pedidoId])
  @@map("pedido_items")
}
