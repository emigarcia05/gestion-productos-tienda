generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Lista Proveedores ─────────────────────────────────────────────────────

model Proveedor {
  id                 String             @id @default(cuid())
  nombre             String
  codigoUnico        String             @unique
  sufijo             String             @unique
  productosProveedor ProductoProveedor[]
  pedidos            Pedido[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@map("proveedores")
}

/// Productos de la lista de proveedores. Vinculados a ItemTienda por codigoExterno.
/// @map en minúsculas: en PostgreSQL los nombres sin comillas se guardan en lowercase.
model ProductoProveedor {
  id                   String     @id @default(cuid())
  codigoExterno        String     @unique @map("codigoexterno")
  codProdProv          String     @map("codprodprov")
  descripcion          String
  precioLista          Float      @map("preciolista")
  precioVentaSugerido  Float      @map("precioventasugerido")
  descuentoProducto   Float      @default(0) @map("descuentoproducto")
  descuentoCantidad    Float      @default(0) @map("descuentocantidad")
  cxTransporte         Float      @default(0) @map("cxtransporte")
  disponible           Boolean    @default(true)
  proveedorId          String     @map("proveedorid")
  proveedor            Proveedor  @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  tienda               ItemTienda[]
  createdAt            DateTime   @default(now()) @map("createdat")
  updatedAt            DateTime   @updatedAt @map("updatedat")

  @@index([proveedorId])
  @@index([codigoExterno])
  @@map("lista_proveedores")
}

model ImportLog {
  id          String   @id @default(cuid())
  filename    String
  status      String   @default("pending")
  totalRows   Int      @default(0)
  creados     Int      @default(0)
  actualizados Int     @default(0)
  eliminados  Int      @default(0)
  errores     Int      @default(0)
  proveedorId String?
  createdAt   DateTime @default(now())

  @@map("import_logs")
}

// ─── Lista Tienda (API Dux / TiendaColor) ──────────────────────────────────

/// Ítems de la lista tienda. Relación formal con ProductoProveedor vía productoProveedorId (codigoExterno).
/// @map en minúsculas: en PostgreSQL los nombres sin comillas se guardan en lowercase.
model ItemTienda {
  id                   String             @id @default(cuid())
  codItem              String             @unique @map("coditem")
  codigoExterno        String?            @map("codigoexterno")
  descripcion          String
  rubro                String?
  subRubro             String?            @map("subrubro")
  marca                String?
  proveedorDux         String?            @map("proveedordux")
  costo                Float              @default(0)
  porcIva              Float              @default(21) @map("porciva")
  precioLista          Float              @default(0) @map("preciolista")
  precioMayorista      Float              @default(0) @map("preciomayorista")
  stockGuaymallen      Float              @default(0) @map("stockguaymallen")
  stockMaipu           Float              @default(0) @map("stockmaipu")
  habilitado           Boolean            @default(true)
  ultimaImpresion      DateTime?          @map("ultimaimpresion")
  productoProveedorId  String?            @map("productoproveedorid")
  productoProveedor    ProductoProveedor? @relation(fields: [productoProveedorId], references: [id], onDelete: SetNull)
  createdAt            DateTime           @default(now()) @map("createdat")
  updatedAt            DateTime           @updatedAt @map("updatedat")

  @@index([codigoExterno])
  @@index([rubro])
  @@index([marca])
  @@index([habilitado])
  @@map("lista_tienda")
}

model SyncLog {
  id             String   @id @default(cuid())
  tipo           String   @default("auto")
  status         String   @default("ok")
  creados        Int      @default(0)
  actualizados   Int      @default(0)
  deshabilitados Int      @default(0)
  totalApi       Int      @default(0)
  duracionMs     Int      @default(0)
  error          String?
  createdAt      DateTime @default(now())

  @@map("sync_logs")
}

// ─── Pedidos a proveedores ─────────────────────────────────────────────────

model Pedido {
  id          String       @id @default(cuid())
  tipo        String
  estado      String       @default("borrador")
  sucursal    String
  proveedorId String
  proveedor   Proveedor    @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  items       PedidoItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([proveedorId])
  @@map("pedidos")
}

model PedidoItem {
  id                   String  @id @default(cuid())
  pedidoId             String
  pedido               Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  codExt               String
  codTienda            String
  descripcionProveedor String
  descripcionTienda    String
  cantidad             Int     @default(1)

  @@index([pedidoId])
  @@map("pedido_items")
}
